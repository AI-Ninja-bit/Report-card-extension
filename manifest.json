{
  "manifest_version": 3,
  "name": "Prerna Report Card Generator",
  "version": "1.0",
  "description": "Generate PS Odahatha report cards from UP Prerna",

  "permissions": [
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "*://*.prerna.up.gov.in/*",
    "*://*.prernaup.in/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "*://*.prerna.up.gov.in/*",
        "*://*.prernaup.in/*"
      ],

      "js": [
        "html2pdf.bundle.min.js",
        "reportTemplate.js",
        "content.js"
      ],

      "css": [
        "styles.css"
      ],

      "run_at": "document_idle"
    }
  ]
}